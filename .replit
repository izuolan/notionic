modules = ["nodejs-20", "web", "bash", "postgresql-16"]
run = "pnpm dev"

[nix]
channel = "stable-24_05"

[deployment]
run = ["sh", "-c", "pnpm dev"]

[[ports]]
localPort = 5000
externalPort = 80

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm dev"
waitForPort = 5000

[userenv]

[userenv.shared]
